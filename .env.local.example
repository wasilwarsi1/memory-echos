# ─────────────────────────────────────────────────────────────
# Neon Database
# Get this from: https://console.neon.tech → your project → Connect
# Use the POOLED connection string for the app (has -pooler in hostname)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Direct connection (no pooler) — used only for migrations
DATABASE_URL_DIRECT="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Echo radius in metres (how far users can see echoes)
ECHO_RADIUS_METERS=100

# Echo TTL in hours (how long echoes live)
ECHO_TTL_HOURS=24
